generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  email         String         @unique
  name          String
  phone         String?
  password      String
  role          Role           @default(USER)
  orders        Order[]
  requests      Request[]
  conversations Conversation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  description String?
  image       String?
  seoTitle    String?
  seoDesc     String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String
  shortDesc   String?
  priceFrom   Float?
  images      String[]
  categoryId  String   @db.ObjectId
  category    Category @relation(fields: [categoryId], references: [id])
  materials   String[]
  dimensions  Json?
  features    String[]
  customOpts  Json?
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  seoTitle    String?
  seoDesc     String?
  seoKeywords String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

model Order {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?     @db.ObjectId
  user       User?       @relation(fields: [userId], references: [id])
  status     OrderStatus @default(PENDING)
  items      Json
  totalPrice Float?
  notes      String?
  params     Json?
  contact    Json
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("orders")
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Request {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  userId         String?       @db.ObjectId
  user           User?         @relation(fields: [userId], references: [id])
  productType    String
  dimensions     Json?
  material       String?
  color          String?
  baseFinish     String?
  finish         String?
  options        Json?
  referenceFiles String[]
  name           String
  email          String
  phone          String?
  message        String?
  status         RequestStatus @default(NEW)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("requests")
}

enum RequestStatus {
  NEW
  IN_REVIEW
  QUOTED
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Article {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  image         String?
  imageCaption  String?
  tags          String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  seoTitle    String?
  seoDesc     String?
  seoKeywords String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("articles")
}

model Banner {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  subtitle  String?
  image     String
  link      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model SiteSettings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model Project {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  slug          String   @unique
  excerpt       String?
  content       String
  images        String[]
  acousticModel String?
  height        String?
  materials     String[]
  finish        String?
  price         Float?
  city          String?
  tags          String[]
  isPublished   Boolean  @default(false)
  sortOrder     Int      @default(0)
  seoTitle      String?
  seoDesc       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("projects")
}

model Media {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  url       String
  type      String
  size      Int
  alt       String?
  createdAt DateTime @default(now())

  @@map("media")
}

model Conversation {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @unique @db.ObjectId
  user          User      @relation(fields: [userId], references: [id])
  messages      Message[]
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("conversations")
}

model Message {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String       @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String       @db.ObjectId
  senderRole     String
  text           String?
  imageUrl       String?
  createdAt      DateTime     @default(now())
  readAt         DateTime?

  @@map("messages")
}
